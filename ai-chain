#!/bin/bash
# ai-chain — Gemini drafts, Claude reviews
# Usage: ai-chain [--mode review|compare|debate] [--ensemble [N]] [--file <path>] [--save] [--quiet] "your prompt"

MODEL="auto-gemini-3"

MODE="review"
FILE_PATH=""
SAVE=false
QUIET=false
ENSEMBLE=false
ENSEMBLE_N=3
ARGS=()

# Parse flags
while [[ $# -gt 0 ]]; do
  case "$1" in
    --mode)
      MODE="$2"
      shift 2
      ;;
    --ensemble)
      ENSEMBLE=true
      # Check if next arg is a digit 1-5
      if [[ "$2" =~ ^[1-5]$ ]]; then
        ENSEMBLE_N="$2"
        shift 2
      else
        shift
      fi
      ;;
    --file)
      FILE_PATH="$2"
      shift 2
      ;;
    --save)
      SAVE=true
      shift
      ;;
    --quiet)
      QUIET=true
      shift
      ;;
    *)
      ARGS+=("$1")
      shift
      ;;
  esac
done

PROMPT="${ARGS[*]}"
STDIN_DATA=""

# Read stdin if piped (not a TTY)
if ! [ -t 0 ]; then
  STDIN_DATA=$(cat)
  # If no prompt provided, use stdin as the prompt
  if [ -z "$PROMPT" ]; then
    PROMPT="$STDIN_DATA"
    STDIN_DATA=""
  fi
fi

# Read --file contents
FILE_CONTENTS=""
if [ -n "$FILE_PATH" ]; then
  if [ ! -f "$FILE_PATH" ]; then
    echo "Error: file not found: $FILE_PATH"
    exit 1
  fi
  FILE_CONTENTS=$(cat "$FILE_PATH")
fi

if [ -z "$PROMPT" ] && [ -z "$FILE_CONTENTS" ]; then
  echo "Usage: ai-chain [--mode review|compare|debate] [--ensemble [N]] [--file <path>] [--save] [--quiet] <prompt>"
  echo ""
  echo "Modes:"
  echo "  review   (default) Gemini answers, Claude reviews/corrects"
  echo "  compare  Both answer independently, shown side by side"
  echo "  debate   Gemini answers → Claude challenges → Gemini has final word"
  echo ""
  echo "Flags:"
  echo "  --ensemble [N]  Run N parallel Gemini perspectives (default 3, max 5), Claude synthesizes"
  echo "  --file <path>   Append file contents to prompt"
  echo "  --save          Save output to ~/ai-chain-YYYY-MM-DD-HHMMSS.md"
  echo "  --quiet         Suppress banners"
  echo ""
  echo "Pipe support:"
  echo "  cat file.py | ai-chain \"explain this\""
  echo "  echo \"what is X\" | ai-chain"
  exit 1
fi

# Build the full prompt sent to Gemini/Claude
build_full_prompt() {
  local prompt="$1"
  local result="$prompt"

  if [ -n "$FILE_CONTENTS" ]; then
    result="$prompt

--- File: $FILE_PATH ---
$FILE_CONTENTS"
  fi

  if [ -n "$STDIN_DATA" ]; then
    result="$prompt

--- Piped Input ---
$STDIN_DATA"
  fi

  echo "$result"
}

FULL_PROMPT=$(build_full_prompt "$PROMPT")

# Output collector (used by --save)
OUTPUT=""

emit() {
  local text="$1"
  printf '%s\n' "$text"
  OUTPUT+="$text"$'\n'
}

banner() {
  local label="$1"
  if [ "$QUIET" = false ]; then
    printf '\n━━━ %s ━━━\n\n' "$label"
    OUTPUT+=$'\n'"━━━ $label ━━━"$'\n\n'
  fi
}

run_gemini() {
  local prompt="$1"
  gemini -m "$MODEL" -p "$prompt" 2>/dev/null
}

run_claude() {
  local prompt="$1"
  claude -p "$prompt" 2>/dev/null
}

# Warn if --ensemble is used with a non-review mode
if [ "$ENSEMBLE" = true ] && [ "$MODE" != "review" ]; then
  echo "Warning: --ensemble is only supported in review mode. Falling back to single Gemini."
  ENSEMBLE=false
fi

# ── COMPARE MODE ──────────────────────────────────────────────────────────────
if [ "$MODE" = "compare" ]; then
  banner "Gemini ($MODEL) answering..."

  GEMINI_RESPONSE=$(run_gemini "$FULL_PROMPT")
  GEMINI_EXIT=$?
  if [ $GEMINI_EXIT -ne 0 ]; then
    echo "Error: gemini failed (exit $GEMINI_EXIT). Run 'gemini' interactively to authenticate first."
    exit 1
  fi
  emit "$GEMINI_RESPONSE"

  banner "Claude answering independently..."

  CLAUDE_RESPONSE=$(run_claude "Answer the following question on your own — do not reference any other AI's response:

$FULL_PROMPT")
  emit "$CLAUDE_RESPONSE"

# ── DEBATE MODE ───────────────────────────────────────────────────────────────
elif [ "$MODE" = "debate" ]; then
  banner "Gemini ($MODEL) opening..."

  GEMINI_RESPONSE=$(run_gemini "$FULL_PROMPT")
  GEMINI_EXIT=$?
  if [ $GEMINI_EXIT -ne 0 ]; then
    echo "Error: gemini failed (exit $GEMINI_EXIT). Run 'gemini' interactively to authenticate first."
    exit 1
  fi
  emit "$GEMINI_RESPONSE"

  banner "Claude challenging..."

  CHALLENGE_PROMPT="Gemini was asked: $FULL_PROMPT

Gemini's answer:
$GEMINI_RESPONSE

Challenge this answer. Find weaknesses, missing nuance, or counterarguments. Be direct and push back where you disagree. Don't simply confirm it."

  CLAUDE_CHALLENGE=$(run_claude "$CHALLENGE_PROMPT")
  emit "$CLAUDE_CHALLENGE"

  banner "Gemini has the final word..."

  FINAL_PROMPT="You previously answered this question: $FULL_PROMPT

Your answer was:
$GEMINI_RESPONSE

Claude challenged it with:
$CLAUDE_CHALLENGE

Respond to the challenge. Defend valid points, concede where Claude is right, and give your final refined answer."

  FINAL_RESPONSE=$(run_gemini "$FINAL_PROMPT")
  FINAL_EXIT=$?
  if [ $FINAL_EXIT -ne 0 ]; then
    echo "Error: gemini failed on final word (exit $FINAL_EXIT)."
    exit 1
  fi
  emit "$FINAL_RESPONSE"

# ── REVIEW MODE (default) ─────────────────────────────────────────────────────
else
  # Ensemble mode: warn if combined with non-review modes (handled above),
  # run N parallel Gemini perspectives, Claude synthesizes.
  if [ "$ENSEMBLE" = true ]; then
    # Warn if somehow ensemble reached a non-review path (safety net)
    banner "Ensemble: $ENSEMBLE_N perspectives running in parallel..."

    LENS_1="Answer directly and technically. Be precise and accurate."
    LENS_2="Think step by step, showing your reasoning process as you go."
    LENS_3="Identify potential issues, edge cases, or common misconceptions about this topic."
    LENS_4="Give a practical, example-driven answer. Use concrete examples wherever possible."
    LENS_5="Answer as a deep domain expert. Assume the reader is also technical and use precise terminology."

    LENS_LABEL_1="Direct"
    LENS_LABEL_2="Reasoning"
    LENS_LABEL_3="Critical"
    LENS_LABEL_4="Practical"
    LENS_LABEL_5="Expert"

    ENSEMBLE_TMP=$(mktemp -d)

    # Fire N parallel Gemini calls
    for i in $(seq 1 "$ENSEMBLE_N"); do
      eval "LENS=\$LENS_$i"
      gemini -m "$MODEL" -p "$FULL_PROMPT

$LENS" > "$ENSEMBLE_TMP/$i.txt" 2>/dev/null &
    done
    wait

    # Build synthesis prompt
    SYNTHESIS_PROMPT="You have received $ENSEMBLE_N independent responses to the same question, each approached from a different angle. Synthesize the best possible answer — combine accurate information, resolve contradictions, discard errors, fill gaps. Do not mention the individual perspectives.

Question: $FULL_PROMPT
"

    for i in $(seq 1 "$ENSEMBLE_N"); do
      eval "LABEL=\$LENS_LABEL_$i"
      PERSPECTIVE=$(cat "$ENSEMBLE_TMP/$i.txt")
      SYNTHESIS_PROMPT="$SYNTHESIS_PROMPT
[Perspective $i — $LABEL]:
$PERSPECTIVE
"
    done

    SYNTHESIS_PROMPT="$SYNTHESIS_PROMPT
Synthesize these into one authoritative, concise answer."

    rm -rf "$ENSEMBLE_TMP"

    banner "Claude synthesizing $ENSEMBLE_N perspectives..."

    CLAUDE_RESPONSE=$(run_claude "$SYNTHESIS_PROMPT")
    emit "$CLAUDE_RESPONSE"

  else
    banner "Gemini ($MODEL) is thinking..."

    GEMINI_RESPONSE=$(run_gemini "$FULL_PROMPT")
    GEMINI_EXIT=$?
    if [ $GEMINI_EXIT -ne 0 ]; then
      echo "Error: gemini failed (exit $GEMINI_EXIT). Run 'gemini' interactively to authenticate first."
      exit 1
    fi
    emit "$GEMINI_RESPONSE"

    banner "Claude is reviewing..."

    REVIEW_PROMPT="Original question:
$FULL_PROMPT

Gemini's answer:
$GEMINI_RESPONSE

Please review Gemini's answer above. If it's correct and complete, confirm it briefly and add anything useful. If there are errors, gaps, or improvements — fix them and explain what changed. Be concise."

    CLAUDE_RESPONSE=$(run_claude "$REVIEW_PROMPT")
    emit "$CLAUDE_RESPONSE"
  fi
fi

# ── SAVE ──────────────────────────────────────────────────────────────────────
if [ "$SAVE" = true ]; then
  TIMESTAMP=$(date +%Y-%m-%d-%H%M%S)
  SAVE_FILE="$HOME/ai-chain-$TIMESTAMP.md"
  {
    echo "# ai-chain: $PROMPT"
    echo ""
    echo "_Generated: $(date) | Model: $MODEL | Mode: $MODE_"
    echo ""
    echo "$OUTPUT"
  } > "$SAVE_FILE"
  echo ""
  echo "Saved to: $SAVE_FILE"
fi
